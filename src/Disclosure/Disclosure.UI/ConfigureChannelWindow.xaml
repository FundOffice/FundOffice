<Window
    x:Class="FMO.Disclosure.ConfigureChannelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FMO.Disclosure"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="配置信批通道"
    Width="350"
    Height="350"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <DockPanel>
        <DockPanel.Resources>
            <DataTemplate x:Key="ChannelTpl">
                <TextBlock Text="{Binding Name}" />
            </DataTemplate>



            <DataTemplate DataType="{x:Type local:EmailChannelConfigViewModel}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Width" Value="60" />
                        </Style>

                        <Style TargetType="BulletDecorator">
                            <Setter Property="Margin" Value="0,1" />
                        </Style>
                    </StackPanel.Resources>
                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="SMTP" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding SmtpHost}" />
                    </BulletDecorator>

                    <DockPanel>
                        <TextBlock Text="Port" />
                        <TextBox Width="50" Text="{Binding SmtpPort}" />

                        <CheckBox
                            Margin="8,0"
                            Content="SSL"
                            IsChecked="{Binding UseSsl}" />
                    </DockPanel>

                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="用户名" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding UserName}" />
                    </BulletDecorator>


                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="授权码" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding Password}" />
                    </BulletDecorator>

                </StackPanel>
            </DataTemplate>


            <DataTemplate DataType="{x:Type local:PfidChannelConfigViewModel}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Width" Value="60" />
                        </Style>

                        <Style TargetType="BulletDecorator">
                            <Setter Property="Margin" Value="0,1" />
                        </Style>
                    </StackPanel.Resources>


                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="用户名" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding UserName}" />
                    </BulletDecorator>


                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="密码" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding Password}" />
                    </BulletDecorator>

                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="密钥" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding Secret}" />
                    </BulletDecorator>
                </StackPanel>
            </DataTemplate>


            <DataTemplate DataType="{x:Type local:MeiShiChannelConfigViewModel}">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Width" Value="60" />
                        </Style>

                        <Style TargetType="BulletDecorator">
                            <Setter Property="Margin" Value="0,1" />
                        </Style>
                    </StackPanel.Resources>


                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="用户名" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding UserName}" />
                    </BulletDecorator>


                    <BulletDecorator>
                        <BulletDecorator.Bullet>
                            <TextBlock Text="密码" />
                        </BulletDecorator.Bullet>
                        <TextBox Text="{Binding Password}" />
                    </BulletDecorator>

                </StackPanel>
            </DataTemplate>




        </DockPanel.Resources>


        <DockPanel DataContext="{Binding Config}" DockPanel.Dock="Bottom">
            <TextBlock
                Margin="5,2"
                DockPanel.Dock="Bottom"
                Foreground="Red"
                Text="{Binding Error}"
                TextWrapping="Wrap" />
            <Button
                Margin="5,2"
                HorizontalAlignment="Stretch"
                Command="{Binding SaveCommand}"
                Content="保存"
                Style="{StaticResource ButtonPrimary}" />
        </DockPanel>

        <ContentControl Margin="8" Content="{Binding Config}" />
    </DockPanel>

</Window>
